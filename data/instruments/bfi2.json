{
  "instrument_id": "bfi2",
  "name": "大五人格量表第二版 (Big Five Inventory-2)",
  "version": "2.0",
  "citation": "Soto, C. J., & John, O. P. (2017). The next Big Five Inventory (BFI-2): Developing and assessing a hierarchical model with 15 facets to enhance bandwidth, fidelity, and predictive power. Journal of Personality and Social Psychology, 113(1), 117-143.",
  "response_scale": {
    "type": "likert",
    "points": 5,
    "labels": {
      "1": "完全不同意",
      "2": "有点不同意",
      "3": "中立",
      "4": "有点同意",
      "5": "完全同意"
    }
  },
  "instructions": "以下是一些可能描述或可能不描述你的陈述。请评价你对每条陈述的同意程度。请如实回答——没有对错之分。",
  "domains": {
    "openness": {"name": "开放性", "abbreviation": "O"},
    "conscientiousness": {"name": "尽责性", "abbreviation": "C"},
    "extraversion": {"name": "外倾性", "abbreviation": "E"},
    "agreeableness": {"name": "宜人性", "abbreviation": "A"},
    "neuroticism": {"name": "神经质", "abbreviation": "N"}
  },
  "facets": {
    "o_intellectual_curiosity": {"name": "求知欲", "domain": "openness"},
    "o_aesthetic_sensitivity": {"name": "审美感受", "domain": "openness"},
    "o_creative_imagination": {"name": "创造性想象", "domain": "openness"},
    "c_organization": {"name": "条理性", "domain": "conscientiousness"},
    "c_productiveness": {"name": "高效性", "domain": "conscientiousness"},
    "c_responsibility": {"name": "责任感", "domain": "conscientiousness"},
    "e_sociability": {"name": "社交性", "domain": "extraversion"},
    "e_assertiveness": {"name": "自信主导", "domain": "extraversion"},
    "e_energy_level": {"name": "活力水平", "domain": "extraversion"},
    "a_compassion": {"name": "同情心", "domain": "agreeableness"},
    "a_respectfulness": {"name": "尊重他人", "domain": "agreeableness"},
    "a_trust": {"name": "信任", "domain": "agreeableness"},
    "n_anxiety": {"name": "焦虑", "domain": "neuroticism"},
    "n_depression": {"name": "抑郁倾向", "domain": "neuroticism"},
    "n_emotional_volatility": {"name": "情绪波动", "domain": "neuroticism"}
  },
  "items": [
    {"id": "bfi2_o_01", "text": "我对艺术、音乐或文学着迷。", "domain": "openness", "facet": "o_aesthetic_sensitivity", "reverse_keyed": false, "order": 1},
    {"id": "bfi2_o_02", "text": "我避免进行知识性的、哲学性的讨论。", "domain": "openness", "facet": "o_intellectual_curiosity", "reverse_keyed": true, "order": 2},
    {"id": "bfi2_o_03", "text": "我富有想象力，善于创造。", "domain": "openness", "facet": "o_creative_imagination", "reverse_keyed": false, "order": 3},
    {"id": "bfi2_o_04", "text": "我对抽象概念不感兴趣。", "domain": "openness", "facet": "o_intellectual_curiosity", "reverse_keyed": true, "order": 4},
    {"id": "bfi2_o_05", "text": "我对美的事物有敏锐的感受力。", "domain": "openness", "facet": "o_aesthetic_sensitivity", "reverse_keyed": false, "order": 5},
    {"id": "bfi2_o_06", "text": "我喜欢提出新的做事方式。", "domain": "openness", "facet": "o_creative_imagination", "reverse_keyed": false, "order": 6},
    {"id": "bfi2_o_07", "text": "我对各种各样的知识话题都很好奇。", "domain": "openness", "facet": "o_intellectual_curiosity", "reverse_keyed": false, "order": 7},
    {"id": "bfi2_o_08", "text": "我很少有艺术或美的体验。", "domain": "openness", "facet": "o_aesthetic_sensitivity", "reverse_keyed": true, "order": 8},
    {"id": "bfi2_o_09", "text": "我经常想出新点子。", "domain": "openness", "facet": "o_creative_imagination", "reverse_keyed": false, "order": 9},
    {"id": "bfi2_o_10", "text": "我对深入思考事物没有兴趣。", "domain": "openness", "facet": "o_intellectual_curiosity", "reverse_keyed": true, "order": 10},
    {"id": "bfi2_o_11", "text": "我认为艺术和自然美景很重要。", "domain": "openness", "facet": "o_aesthetic_sensitivity", "reverse_keyed": false, "order": 11},
    {"id": "bfi2_o_12", "text": "我很难想象出新的事物。", "domain": "openness", "facet": "o_creative_imagination", "reverse_keyed": true, "order": 12},

    {"id": "bfi2_c_01", "text": "我做事有条理，喜欢整洁有序。", "domain": "conscientiousness", "facet": "c_organization", "reverse_keyed": false, "order": 13},
    {"id": "bfi2_c_02", "text": "我一旦开始做一件事就会坚持到底。", "domain": "conscientiousness", "facet": "c_productiveness", "reverse_keyed": false, "order": 14},
    {"id": "bfi2_c_03", "text": "我是值得依赖的，说话算数。", "domain": "conscientiousness", "facet": "c_responsibility", "reverse_keyed": false, "order": 15},
    {"id": "bfi2_c_04", "text": "我有时做事粗心大意。", "domain": "conscientiousness", "facet": "c_organization", "reverse_keyed": true, "order": 16},
    {"id": "bfi2_c_05", "text": "我做事高效，能快速完成任务。", "domain": "conscientiousness", "facet": "c_productiveness", "reverse_keyed": false, "order": 17},
    {"id": "bfi2_c_06", "text": "我有时行为不负责任。", "domain": "conscientiousness", "facet": "c_responsibility", "reverse_keyed": true, "order": 18},
    {"id": "bfi2_c_07", "text": "我经常把东西乱放，找不到。", "domain": "conscientiousness", "facet": "c_organization", "reverse_keyed": true, "order": 19},
    {"id": "bfi2_c_08", "text": "我有时做事拖延。", "domain": "conscientiousness", "facet": "c_productiveness", "reverse_keyed": true, "order": 20},
    {"id": "bfi2_c_09", "text": "我是一个可靠的人。", "domain": "conscientiousness", "facet": "c_responsibility", "reverse_keyed": false, "order": 21},
    {"id": "bfi2_c_10", "text": "我喜欢保持物品整洁有序。", "domain": "conscientiousness", "facet": "c_organization", "reverse_keyed": false, "order": 22},
    {"id": "bfi2_c_11", "text": "我做事有始有终，不半途而废。", "domain": "conscientiousness", "facet": "c_productiveness", "reverse_keyed": false, "order": 23},
    {"id": "bfi2_c_12", "text": "我遵守规则，履行承诺。", "domain": "conscientiousness", "facet": "c_responsibility", "reverse_keyed": false, "order": 24},

    {"id": "bfi2_e_01", "text": "我是外向的、善于交际的。", "domain": "extraversion", "facet": "e_sociability", "reverse_keyed": false, "order": 25},
    {"id": "bfi2_e_02", "text": "我在群体中喜欢担任领导角色。", "domain": "extraversion", "facet": "e_assertiveness", "reverse_keyed": false, "order": 26},
    {"id": "bfi2_e_03", "text": "我充满活力，总是很活跃。", "domain": "extraversion", "facet": "e_energy_level", "reverse_keyed": false, "order": 27},
    {"id": "bfi2_e_04", "text": "我更喜欢独自一人。", "domain": "extraversion", "facet": "e_sociability", "reverse_keyed": true, "order": 28},
    {"id": "bfi2_e_05", "text": "我敢于表达自己的观点。", "domain": "extraversion", "facet": "e_assertiveness", "reverse_keyed": false, "order": 29},
    {"id": "bfi2_e_06", "text": "我很少感到精力充沛。", "domain": "extraversion", "facet": "e_energy_level", "reverse_keyed": true, "order": 30},
    {"id": "bfi2_e_07", "text": "我喜欢与人交谈。", "domain": "extraversion", "facet": "e_sociability", "reverse_keyed": false, "order": 31},
    {"id": "bfi2_e_08", "text": "我在各种场合都很安静。", "domain": "extraversion", "facet": "e_assertiveness", "reverse_keyed": true, "order": 32},
    {"id": "bfi2_e_09", "text": "我展现出很多热情和活力。", "domain": "extraversion", "facet": "e_energy_level", "reverse_keyed": false, "order": 33},
    {"id": "bfi2_e_10", "text": "我在社交场合话不多。", "domain": "extraversion", "facet": "e_sociability", "reverse_keyed": true, "order": 34},
    {"id": "bfi2_e_11", "text": "在群体中，我倾向于让他人带头。", "domain": "extraversion", "facet": "e_assertiveness", "reverse_keyed": true, "order": 35},
    {"id": "bfi2_e_12", "text": "我是一个充满热情的人。", "domain": "extraversion", "facet": "e_energy_level", "reverse_keyed": false, "order": 36},

    {"id": "bfi2_a_01", "text": "我对他人的感受有同理心。", "domain": "agreeableness", "facet": "a_compassion", "reverse_keyed": false, "order": 37},
    {"id": "bfi2_a_02", "text": "我对待他人尊重且有礼貌。", "domain": "agreeableness", "facet": "a_respectfulness", "reverse_keyed": false, "order": 38},
    {"id": "bfi2_a_03", "text": "我相信大多数人都是善良的。", "domain": "agreeableness", "facet": "a_trust", "reverse_keyed": false, "order": 39},
    {"id": "bfi2_a_04", "text": "我对别人的问题不感兴趣。", "domain": "agreeableness", "facet": "a_compassion", "reverse_keyed": true, "order": 40},
    {"id": "bfi2_a_05", "text": "我有时对别人粗鲁。", "domain": "agreeableness", "facet": "a_respectfulness", "reverse_keyed": true, "order": 41},
    {"id": "bfi2_a_06", "text": "我对别人的意图持怀疑态度。", "domain": "agreeableness", "facet": "a_trust", "reverse_keyed": true, "order": 42},
    {"id": "bfi2_a_07", "text": "我关心他人的福祉。", "domain": "agreeableness", "facet": "a_compassion", "reverse_keyed": false, "order": 43},
    {"id": "bfi2_a_08", "text": "我善于与人合作，不制造冲突。", "domain": "agreeableness", "facet": "a_respectfulness", "reverse_keyed": false, "order": 44},
    {"id": "bfi2_a_09", "text": "我相信别人都是诚实正直的。", "domain": "agreeableness", "facet": "a_trust", "reverse_keyed": false, "order": 45},
    {"id": "bfi2_a_10", "text": "我对他人的情感需求不太敏感。", "domain": "agreeableness", "facet": "a_compassion", "reverse_keyed": true, "order": 46},
    {"id": "bfi2_a_11", "text": "我有时会找借口批评别人。", "domain": "agreeableness", "facet": "a_respectfulness", "reverse_keyed": true, "order": 47},
    {"id": "bfi2_a_12", "text": "我对他人倾向于看到好的一面。", "domain": "agreeableness", "facet": "a_trust", "reverse_keyed": false, "order": 48},

    {"id": "bfi2_n_01", "text": "我经常感到担心和焦虑。", "domain": "neuroticism", "facet": "n_anxiety", "reverse_keyed": false, "order": 49},
    {"id": "bfi2_n_02", "text": "我有时感到悲伤或抑郁。", "domain": "neuroticism", "facet": "n_depression", "reverse_keyed": false, "order": 50},
    {"id": "bfi2_n_03", "text": "我的情绪变化很大。", "domain": "neuroticism", "facet": "n_emotional_volatility", "reverse_keyed": false, "order": 51},
    {"id": "bfi2_n_04", "text": "我在压力下保持冷静。", "domain": "neuroticism", "facet": "n_anxiety", "reverse_keyed": true, "order": 52},
    {"id": "bfi2_n_05", "text": "我对生活总体上感到满意。", "domain": "neuroticism", "facet": "n_depression", "reverse_keyed": true, "order": 53},
    {"id": "bfi2_n_06", "text": "我的情绪稳定，不容易波动。", "domain": "neuroticism", "facet": "n_emotional_volatility", "reverse_keyed": true, "order": 54},
    {"id": "bfi2_n_07", "text": "我容易紧张不安。", "domain": "neuroticism", "facet": "n_anxiety", "reverse_keyed": false, "order": 55},
    {"id": "bfi2_n_08", "text": "我经常情绪低落。", "domain": "neuroticism", "facet": "n_depression", "reverse_keyed": false, "order": 56},
    {"id": "bfi2_n_09", "text": "我能很好地控制自己的情绪。", "domain": "neuroticism", "facet": "n_emotional_volatility", "reverse_keyed": true, "order": 57},
    {"id": "bfi2_n_10", "text": "我很少为事情担心。", "domain": "neuroticism", "facet": "n_anxiety", "reverse_keyed": true, "order": 58},
    {"id": "bfi2_n_11", "text": "我经常感到无助和沮丧。", "domain": "neuroticism", "facet": "n_depression", "reverse_keyed": false, "order": 59},
    {"id": "bfi2_n_12", "text": "别人说我情绪忽高忽低。", "domain": "neuroticism", "facet": "n_emotional_volatility", "reverse_keyed": false, "order": 60}
  ]
}
