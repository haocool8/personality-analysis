{
  "instrument_id": "rses",
  "name": "Rosenberg 自尊量表 (Rosenberg Self-Esteem Scale)",
  "version": "1.0",
  "citation": "Rosenberg, M. (1965). Society and the adolescent self-image. Princeton University Press.",
  "response_scale": {
    "type": "likert",
    "points": 4,
    "labels": {
      "1": "非常不同意",
      "2": "不同意",
      "3": "同意",
      "4": "非常同意"
    }
  },
  "instructions": "以下陈述涉及你对自己的一般感受。请指出你对每条陈述的同意程度。",
  "domains": {
    "self_esteem": {"name": "自尊", "abbreviation": "SE"}
  },
  "items": [
    {"id": "rses_01", "text": "总体而言，我对自己感到满意。", "reverse_keyed": false, "order": 1},
    {"id": "rses_02", "text": "有时候我觉得自己一无是处。", "reverse_keyed": true, "order": 2},
    {"id": "rses_03", "text": "我觉得自己有一些好的品质。", "reverse_keyed": false, "order": 3},
    {"id": "rses_04", "text": "我能把事情做得和大多数人一样好。", "reverse_keyed": false, "order": 4},
    {"id": "rses_05", "text": "我觉得自己没什么值得骄傲的。", "reverse_keyed": true, "order": 5},
    {"id": "rses_06", "text": "有时候我确实觉得自己很没用。", "reverse_keyed": true, "order": 6},
    {"id": "rses_07", "text": "我觉得自己是一个有价值的人，至少与别人不相上下。", "reverse_keyed": false, "order": 7},
    {"id": "rses_08", "text": "我希望我能对自己更尊重一些。", "reverse_keyed": true, "order": 8},
    {"id": "rses_09", "text": "总的来说，我倾向于觉得自己是个失败者。", "reverse_keyed": true, "order": 9},
    {"id": "rses_10", "text": "我对自己持积极的态度。", "reverse_keyed": false, "order": 10}
  ]
}
